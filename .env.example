# =========================
# Runtime Mode Switch
# =========================
# 可选: deepseek / lab
API_MODE=deepseek

# =========================
# Common Evaluation Tuning
# =========================
EVAL_MAX_WORKERS=8
LLM_MAX_CONCURRENCY=4
LLM_API_RETRY_MAX=3
LLM_API_RETRY_BASE_SECONDS=1.5
EVAL_CANDIDATE_COUNT=3

# =========================
# Mode 0: DeepSeek
# =========================
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
# 可选：若 deepseek 模式也要跑 embedding
DEEPSEEK_EMBED_API_KEY=
DEEPSEEK_EMBED_BASE_URL=
DEEPSEEK_EMBED_MODEL=

# =========================
# Embedding Fallback (Aliyun)
# =========================
# deepseek 模式下，如果你不配置 DEEPSEEK_EMBED_*，会用这里的 embedding 配置
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_EMBED_API_KEY=
ALIYUN_EMBED_BASE_URL=
ALIYUN_EMBED_MODEL=text-embedding-v3

# =========================
# Mode B: Lab vLLM
# =========================
LAB_API_KEY=your_lab_api_key
LAB_CHAT_BASE_URL=https://qwen.nju-slab.cn/v1
LAB_CHAT_MODEL=qwen-local

# 若 embedding key 与 chat 相同，可不填 LAB_EMBED_API_KEY
LAB_EMBED_API_KEY=
LAB_EMBED_BASE_URL=https://embedding.nju-slab.cn/v1
LAB_EMBED_MODEL=intfloat/multilingual-e5-large
